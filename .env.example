APP_NAME="Aternix Error Receiver"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://errors.aternix.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=aternix_reports
DB_USERNAME=
DB_PASSWORD=

# No database tables beyond error_reports are needed:
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file
FILESYSTEM_DISK=local

# HTTP Basic Auth for the /dashboard view.
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# Shared secret clients must send as the X-Report-Token header.
ERROR_REPORT_TOKEN=
# Optional: email each received report here (best-effort).
ERROR_REPORT_NOTIFY_EMAIL=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="reports@aternix.com"
MAIL_FROM_NAME="${APP_NAME}"
